# Variables used by frontend source code.
# Only REACT_APP_* variables are exposed to browser code by Create React App.
# Restart the app after changes.

# Frontend dev server port
PORT=3001

# CoinGecko primary endpoint (optional override)
REACT_APP_SOUL_PRICE_API_URL=

# CoinMarketCap fallback configuration (optional)
REACT_APP_CMC_API_KEY=
REACT_APP_CMC_PROXY_URL=
REACT_APP_CMC_SOUL_QUOTES_API_URL=
REACT_APP_CMC_SOUL_SYMBOL=SOUL
REACT_APP_CMC_ALLOW_BROWSER_DIRECT=false

# Polling/backoff tuning in milliseconds
REACT_APP_SOUL_PRICE_BASE_POLL_INTERVAL_MS=300000
REACT_APP_SOUL_PRICE_MAX_BACKOFF_MS=600000
REACT_APP_SOUL_PRICE_REQUEST_TIMEOUT_MS=7000

# Map graph API configuration
# Point this to the running PhantasmaMaps-api host.
REACT_APP_MAPS_API_BASE_URL=http://localhost:3000
REACT_APP_MAPS_API_TOKEN_SYMBOL=SOUL
# Optional: when set, frontend will call /graph/address/:address
REACT_APP_MAPS_API_ROOT_ADDRESS=
REACT_APP_MAPS_API_GRAPH_DEPTH=2
REACT_APP_MAPS_API_GRAPH_EDGE_LIMIT=1200
REACT_APP_MAPS_API_REQUEST_TIMEOUT_MS=12000

# Explorer URL overrides (optional)
REACT_APP_PHANTASMA_EXPLORER_BASE=
REACT_APP_PHANTASMA_TX_EXPLORER_BASE=

# Public base path for static assets (leave empty for root hosting)
PUBLIC_URL=

# Optional build metadata shown in header for deployment verification
REACT_APP_BUILD_VERSION=
REACT_APP_GIT_SHA=
